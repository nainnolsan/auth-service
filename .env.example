# Server Configuration
PORT=3001
NODE_ENV=development

# Database PostgreSQL (desarrollo local)
# Para desarrollo local con docker-compose:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_service

# Railway/Producción usa DATABASE_URL automáticamente
# No necesitas configurar DB_HOST, DB_PORT, etc en Railway
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secrets (CAMBIAR EN PRODUCCIÓN)
# Genera secretos seguros para producción
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_IN_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_SECRET_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# Desarrollo: permite localhost
# Producción: URL de tu API Gateway
CORS_ORIGIN=http://localhost:5173
