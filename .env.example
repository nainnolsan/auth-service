# Server Configuration
PORT=3001
NODE_ENV=development

# Database PostgreSQL (desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_service

# Railway proporciona DATABASE_URL automáticamente en producción
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secrets
JWT_SECRET=tu_super_secreto_jwt_cambiar_en_produccion
JWT_REFRESH_SECRET=tu_super_secreto_refresh_cambiar_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
# Para producción: https://tu-frontend.vercel.app
